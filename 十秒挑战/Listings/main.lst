  58          //过程
  59          void journey()
  60          {
  61   1        byte_0 = 0;//一系列的初始化，以防万一
  62   1        P2_6 = 1;
  63   1        P2_7 = 1;
  64   1        start_1();//开启计时
  65   1        while (byte_0==0)//刷新数码管，检测按键是否按下
  66   1          {
  67   2            show_num(1,time/1000);
  68   2            show_num(2,(time%1000)/100);
  69   2            show_num(3,(time%100)/10);
  70   2            show_num(4,time%10);
  71   2            show_num(2,10);
  72   2          }
  73   1        TR1 = 0;//关闭计时器1
  74   1        byte_0 = 0;
  75   1        byte_1 = 0;
  76   1        if (time >=990 && time <= 1010)//成绩评估
  77   1          {
  78   2            P2_6 = 0;
  79   2            P2_7 = 0;
  80   2          }
  81   1        else if ((time >=970 && time <990) || (time <= 1030  && time > 1010))
  82   1          {
  83   2            P2_6 = 0;
  84   2          }
  85   1        //结束，显示成绩
  86   1        while (1)
  87   1          {
  88   2            show_num(1,time/1000);
  89   2            show_num(2,(time%1000)/100);    
  90   2            show_num(3,(time%100)/10);
  91   2            show_num(4,time%10);
  92   2            show_num(2,10);
  93   2            if (byte_1 == 1)//检测按键2
  94   2              {
  95   3                byte_1 = 0;
